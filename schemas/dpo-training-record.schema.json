{
  "$defs": {
    "Message": {
      "properties": {
        "role": {
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ],
          "title": "Role",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "tool_calls": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Calls"
        },
        "tool_call_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Call Id"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "title": "Message",
      "type": "object"
    },
    "Provenance": {
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "rollout_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rollout Id"
        },
        "task_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Id"
        },
        "n_gram_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Gram Hash"
        },
        "task_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Hash"
        }
      },
      "required": [
        "source"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "TurnAnnotation": {
      "properties": {
        "turn_index": {
          "title": "Turn Index",
          "type": "integer"
        },
        "loss_weight_tokens": {
          "default": "default",
          "enum": [
            "default",
            "recovery",
            "state_summary",
            "high_value"
          ],
          "title": "Loss Weight Tokens",
          "type": "string"
        }
      },
      "required": [
        "turn_index"
      ],
      "title": "TurnAnnotation",
      "type": "object"
    }
  },
  "description": "DPO preference pair. schema_version: dpo/v1.",
  "properties": {
    "schema_version": {
      "const": "dpo/v1",
      "default": "dpo/v1",
      "title": "Schema Version",
      "type": "string"
    },
    "messages": {
      "items": {
        "$ref": "#/$defs/Message"
      },
      "title": "Messages",
      "type": "array"
    },
    "prompt_messages": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Message"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Messages"
    },
    "chosen": {
      "title": "Chosen",
      "type": "string"
    },
    "rejected": {
      "title": "Rejected",
      "type": "string"
    },
    "loss_weight_tokens": {
      "default": "default",
      "enum": [
        "default",
        "recovery",
        "state_summary",
        "high_value"
      ],
      "title": "Loss Weight Tokens",
      "type": "string"
    },
    "loss_weight_annotations": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/TurnAnnotation"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Loss Weight Annotations"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    }
  },
  "required": [
    "messages",
    "chosen",
    "rejected",
    "provenance"
  ],
  "title": "DpoTrainingRecord",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WasmAgent/trace-pipeline/blob/main/schemas/dpo-training-record.schema.json"
}
