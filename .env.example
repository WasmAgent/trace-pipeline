# trace-pipeline environment variables — copy to .env.local for local dev
#
# trace-pipeline is mostly offline: it reads JSONL fixtures, computes
# statistics, and writes results to disk. The only env vars it needs
# are public keys for verifying signed AEP records emitted by
# wasmagent-js / bscode.

# ── AEP signature verification ───────────────────────────────────────
#
# Each AEPRecord's signature.key_id selects which public key to use.
# Format: WASMAGENT_AEP_PUBKEY_<key_id>=<base64 ed25519 public key>
#
# Public keys are 32 raw bytes, base64-encoded (NOT base64url).
# Generate the public key from a seed with @wasmagent/aep:
#   const signer = createLocalSignerFromSeed("...");
#   console.log(signer.publicKey);   // base64 string
#
# Used by:
#   - evomerge validate-aep --require-signature
#   - evomerge/validate/keystore.py resolve_pubkey()
#
# Example test/CI key (NOT a real production secret):
# WASMAGENT_AEP_PUBKEY_bscode-test=qBxAfH2pT+rZ7VgC8Cj9R5Pj4LXgQyVx7m3kxYzN8sw=
# WASMAGENT_AEP_PUBKEY_wasmagent-js-test=N8Q3rA1mP9xK2vY7tL4wH6sB5cZ0pE3jT8uF1iD9aWg=

# ── Optional: HuggingFace integration ────────────────────────────────
# Only needed for prepare_arxiv.sh and benchmark adapters that fetch
# datasets from HF Hub. The toolkit core does not call HF.
# HF_TOKEN=hf_...
