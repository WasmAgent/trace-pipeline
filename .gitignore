# ── Python build artifacts ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
*.log
*.tgz

# ── Generated by prepare_arxiv.sh; the tar.gz is committed but not the dir.
papers/eval_trust/arxiv_upload/

# ── Training data — never commit real training records or checkpoints
data/training/
data/synthetic/
checkpoints/

# ── ML model artifacts — binary files, not suitable for git ─────────
data/router/*.joblib
data/router/router_records.jsonl
*.joblib
*.pt
*.safetensors
*.gguf
*.bin
outputs/

# ── Local caches (agent scratch, etc.) ──────────────────────────────
.tmp/
tmp/
.cache/
.claude/

# ── Secrets — never commit ──────────────────────────────────────────
# Catch-all for env files, except the committed templates below.
.env
.env.*
!.env.example
!.env.template
.dev.vars
# Private keys / certificates with embedded keys
*.pem
*.key
*.seed
id_rsa
id_rsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*
*.p12
*.pfx
*.jks
*.pkcs12
# Generic credential dumps
secrets.json
secrets.yaml
secrets.yml
.netrc
.git-credentials
# Cloud-provider credential files
gcp-*credentials*.json
service-account*.json
aws-credentials*
.npmrc

# ── OS / editor (per-developer, never per-repo) ─────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
